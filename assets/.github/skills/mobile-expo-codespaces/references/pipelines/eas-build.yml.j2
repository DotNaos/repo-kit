name: {{ workflow_name | default('EAS Build') }}

on:
  workflow_dispatch:
  push:
    branches:
{% for branch in trigger_branches | default(['main']) %}
      - {{ branch }}
{% endfor %}

jobs:
  build:
    runs-on: {{ runner | default('ubuntu-latest') }}
    env:
      EXPO_TOKEN: ${{ secrets.EXPO_TOKEN }}
    steps:
      - uses: actions/checkout@v5

      - uses: actions/setup-node@v6
        with:
          node-version: {{ node_version | default('22') }}

{% if package_manager | default('bun') == 'bun' %}
      - uses: oven-sh/setup-bun@v2
{% endif %}

      - name: Setup Expo and EAS
        uses: expo/expo-github-action@v8
        with:
          eas-version: latest
          token: ${{ secrets.EXPO_TOKEN }}
{% if package_manager | default('bun') == 'bun' %}
          packager: bun
{% endif %}

      - name: Install dependencies
        run: {{ install_cmd | default('bun install --frozen-lockfile') }}

      - name: Trigger EAS build
        run: eas build --platform {{ eas_platform | default('all') }} --profile {{ eas_profile | default('production') }} --non-interactive --no-wait
